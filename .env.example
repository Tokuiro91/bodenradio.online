# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=https://yourdomain.com

# Superadmin email (gets full admin rights, cannot be deleted)
SUPERADMIN_EMAIL=your@email.com

# Admin emails (comma-separated fallback if data/admins.json missing)
ADMIN_EMAILS=your@email.com

# Gmail SMTP (for OTP emails)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# Icecast password (default is "admin" — change it!)
ICECAST_PASSWORD=admin

# Stream URL (public-facing)
NEXT_PUBLIC_STREAM_URL=https://yourdomain.com:8000/radio

# Allowed hosts for /admin route (comma-separated)
ALLOWED_HOSTS=yourdomain.com,localhost,127.0.0.1

# JWT secret for radio-backend
JWT_SECRET=generate-with-openssl-rand-hex-32

# Radio backend admin credentials (used by Next.js to authenticate with radio-backend)
RADIO_BACKEND_USERNAME=admin
RADIO_BACKEND_PASSWORD=change-this-password

# Google Apps Script webhook (for mix submissions)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/.../exec
